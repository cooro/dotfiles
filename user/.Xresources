!
! .Xresources
!

URxvt*scrollBar: false
URxvt*font:     xft:PxPlus IBM CGAthin:size=6:antialias=false:hinting=false
URxvt*boldFont: xft:PxPlus IBM CGA:antialias=false:hinting=false
URxvt*letterSpace: +1
URxvt*lineSpace: +1

!URxvt*inputMethod: ibus
!URxvt*preeditType: OverTheSpot

! uncomment to activate transparency (also needs compositor)
!URxvt*depth: 32

*.foreground:  #ffffff
*.background:  #070a0d

*.cursorColor: #f1f1f0

! black
*.color0:  #000000
*.color8:  #5c6266
! red
*.color1:  #ff0055
*.color9:  #ff0055
! green
*.color2:  #55ff00
*.color10: #55ff00
! yellow
*.color3:  #ff5500
*.color11: #ff5500
! blue
*.color4:  #3377ff
*.color12: #3377ff
! magenta
*.color5:  #7f3fff
*.color13: #7f3fff
! cyan
*.color6:  #00d282
*.color14: #00d282
! white
*.color7:  #acb8bf
*.color15: #ffffff

